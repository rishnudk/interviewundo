## Proposed Changes

### Database Schema (Prisma)

#### [MODIFY] [schema.prisma](file:///d:/interviewUndo/apps/backend-api/src/infrastructure/database/prisma/schema.prisma)

Add new enums and models:

```prisma
enum BattleStatus {
  WAITING        // Matchmaking, waiting for opponent
  IN_PROGRESS    // Both players coding
  COMPLETED      // Timer expired or both submitted
  CANCELLED      // Player left during waiting
  FORFEITED      // Player disconnected mid-battle
}

model Battle {
  id              String       @id @default(cuid())
  status          BattleStatus @default(WAITING)
  problemId       String
  difficulty      Difficulty
  category        Category
  durationSeconds Int          @default(900)  // 15 min default
  startedAt       DateTime?
  endedAt         DateTime?
  winnerId        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  problem         Problem      @relation(fields: [problemId], references: [id])
  participants    BattleParticipant[]

  @@index([status])
  @@index([createdAt])
  @@map("battles")
}

model BattleParticipant {
  id           String   @id @default(cuid())
  battleId     String
  userId       String
  code         String   @db.Text @default("")
  submittedAt  DateTime?
  passedCases  Int      @default(0)
  totalCases   Int      @default(0)
  runtime      Int?     // ms
  score        Int      @default(0)  // calculated score
  createdAt    DateTime @default(now())

  battle       Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([battleId, userId])
  @@index([userId])
  @@map("battle_participants")
}

model BattleChat {
  id        String   @id @default(cuid())
  battleId  String
  userId    String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([battleId, createdAt])
  @@map("battle_chats")
}
```

Also add reverse relations to `User` and `Problem`:
```prisma
// In User model:
battleParticipations BattleParticipant[]

// In Problem model:
battles Battle[]
```

